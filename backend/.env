DB_HOST=localhost
DB_PORT=5432
DB_NAME=jwt
DB_USER=postgres
DB_PASSWORD=postgres

SECRET_KEY=my_super_secret_key_123456
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Gmail SMTP example.
# For Gmail, do not use your normal Gmail password.
# Create an App Password in Google Account -> Security -> 2-Step Verification -> App passwords.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=
OTP_EXPIRE_MINUTES=10
